{
  "name": "openmesh",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-native operations platform — declare what your infrastructure should do, OpenMesh figures out how",
  "license": "MIT",
  "homepage": "https://open-mesh.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/thebotclub/openmesh.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "build": "pnpm -r --sort build",
    "check": "pnpm -r --sort check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint --config oxlintrc.json .",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "prettier": "^3.4.0"
  }
}
